# ─── Required ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Session (set a random string in production) ───────
SESSION_SECRET=change-me-to-a-random-string

# ─── Google OAuth (optional — leave blank to hide button) ──
GOOGLE_CLIENT_ID=your_google_client_id_here

# ─── Email Alerts (optional — leave blank to disable) ──
SMTP_USER=
SMTP_PASS=

# ─── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database (optional — defaults to ./health-data.db) ─
# DB_PATH=/data/health-data.db
